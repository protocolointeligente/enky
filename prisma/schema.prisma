// ENKY OS — Prisma schema
//
// Fase 02A: schema expandido do modelo mínimo da Fase 01 para o modelo
// completo necessário à fundação e ao fluxo central do MVP, seguindo o
// Data Model Specification v1.2.1 (documento de maior hierarquia para
// banco/enums/relações/índices/constraints) e as reconciliações da
// Fase 01.5 (achados F1–F9, ADR-001, ADR-002).
//
// Duas extensões sobre o Data Model v1.2.1 original, ambas aprovadas
// formalmente após o relatório de Fase 02A:
//   - `Session`: infraestrutura de autenticação (ADR-002-authentication.md),
//     não uma entidade de produto do Data Model.
//   - `WorkoutTemplate` + `Workout.workoutTemplateId`: entidade oficial do
//     MVP (aprovada — a Interface Architecture v1.4 já prevê biblioteca de
//     modelos e substituição por template). Regras de clonagem:
//       * um Workout clonado de um template mantém `source = TEMPLATE`
//         permanentemente — não muda para MANUAL após edição;
//       * `contentSnapshot` é copiado no momento da clonagem e nunca mais
//         sincronizado — editar o Workout clonado NUNCA altera o
//         WorkoutTemplate original, e editar o template NUNCA retroage
//         sobre clones já criados (cópia imutável, não referência viva).
//
// Fora do escopo desta fase (ver relatório de Fase 02A): `Notification`
// interna (adiada — decisão: `AthleteInvitation` controla o convite,
// e-mail transacional entrega o link, falhas de envio são logadas;
// notificação interna só entra quando existir central de notificações
// real no produto — não criar tabela "porque pode ser útil"),
// `AthleteGroup`, mensageria completa, anexos genéricos,
// `AIRecommendation` independente (todos classificados como pós-MVP ou
// substituídos em enky_os_specification.md §12).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// 1. ENUMS
// ---------------------------------------------------------------------------

enum Role {
  SUPERADMIN
  ADMIN
  TRAINER
  ATHLETE
}

// Papel do usuário DENTRO da organização (distinto de `Role`, o papel global).
// Etapa 4 §4: a assessoria real precisa de papéis operacionais/financeiros
// separados. Valores novos são ANEXADOS (migração aditiva) — a ordem no enum
// não implica hierarquia; a autoridade é modelada em `modules/organizations/
// org-roles.ts` e imposta por `requireOrgRole`. `ADMIN` é legado (nunca
// atribuído a vínculos novos — o cadastro cria OWNER) e é tratado como MANAGER.
enum OrganizationRole {
  OWNER
  COACH
  ADMIN
  SUPPORT
  MANAGER
  HEAD_COACH
  ASSISTANT_COACH
  FINANCE
  VIEWER
}

enum WorkoutStatus {
  DRAFT
  PUBLISHED
  IN_PROGRESS // Reservado para pós-MVP
  COMPLETED
  PARTIAL
  MISSED
  ARCHIVED
  CANCELLED
}

enum WorkoutCompletionSource {
  ATHLETE_REPORTED
  SYSTEM_EXPIRED
  TRAINER_MARKED
}

enum SessionRpeLoadStatus {
  COMPLETE
  PARTIAL
  NOT_AVAILABLE
  INVALID
}

enum MarketplaceStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum MarketplacePurchaseStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
  DISPUTED
  EXPIRED
}

enum WebhookEventStatus {
  PROCESSED
  IGNORED
  FAILED
}

enum SubscriptionStatus {
  INCOMPLETE
  TRIALING
  ACTIVE
  PAST_DUE
  UNPAID
  PAUSED
  CANCELLED
  EXPIRED
}

enum GenerationMode {
  AUTOMATIC
  ASSISTED
}

enum GenerationBatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum GenerationScope {
  FULL_CYCLE
  MESOCYCLE
  MICROCYCLE
  SINGLE_WEEK
}

enum CalendarEventType {
  PROVA
  VIAGEM
  EXAME
  INDISPONIBILIDADE
}

enum WorkoutStepType {
  TIRO
  RODAGEM
  PAUSA_ATIVA
  PAUSA_PASSIVA
  PROGRESSIVO
  SUBIDA
}

enum IntensityTargetType {
  PACE
  HEART_RATE_ZONE
  POWER
  CADENCE
  RPE
}

enum AuditActorType {
  USER
  SYSTEM
  CRON
  SUPPORT_AGENT
}

enum BillingCycle {
  MENSAL
  ANUAL
}

enum Modality {
  RUNNING
  STRENGTH
  FUNCTIONAL
  CYCLING
  SWIMMING
  TRIATHLON
}

enum ReportStatus {
  DRAFT
  PUBLISHED
  REVOKED
  ARCHIVED
}

enum WorkoutSource {
  MANUAL
  PERIODIZATION_GENERATED
  TEMPLATE
  MARKETPLACE
  IMPORTED
}

enum ConfidenceLevel {
  LOW
  MODERATE
  HIGH
  NOT_ASSESSED
}

enum DerivedMetricStatus {
  PENDING
  CONSOLIDATED
  STALE
  INSUFFICIENT_DATA
  INVALID
}

// Avaliações do atleta (etapa feat/athlete-assessments-prescription-zones).
// Ciclo de vida versionado: uma avaliação nova NÃO apaga a anterior — a antiga
// vira SUPERSEDED e o histórico é preservado. EXPIRED é derivado de validUntil.
enum AssessmentStatus {
  DRAFT
  VALID
  SUPERSEDED
  EXPIRED
  INVALID
}

// Procedência do dado. MEASURED (medido) nunca é substituído silenciosamente
// por ESTIMATED (estimado) — a diferença é sempre visível ao treinador.
enum AssessmentSource {
  MEASURED
  ESTIMATED
  IMPORTED
  MANUAL
  DEVICE
  LAB
  FIELD_TEST
}

// Ciclo de vida do Insight persistido (02H → 03). Máquina de estados completa:
// NEW (exposto, não visto) → VIEWED (treinador abriu) → ACCEPTED/IGNORED (decisão)
// → RESOLVED (situação encerrada, com `outcome` observado). EXPIRED é aplicado
// pela varredura quando a situação some (deixa de ser recalculada) antes de
// qualquer decisão — nunca sobrescreve uma decisão já tomada.
// PENDING é legado (linhas anteriores à Fase 03) e é reconciliado para NEW pela
// migração; mantido no enum só para não quebrar linhas antigas em dev/preview.
enum InsightStatus {
  NEW
  VIEWED
  ACCEPTED
  IGNORED
  RESOLVED
  EXPIRED
  PENDING
}

// Fase 11 — Integrações externas. Enum (e não texto livre) porque cada valor
// exige um adapter escrito: nenhum provedor "aparece" no banco sem código que
// saiba falar com ele.
enum ExternalProvider {
  STRAVA
}

// Fase 06/08 — feature flag global da plataforma. Só SUPERADMIN altera (matriz
// de permissões §3). Flag DESLIGADA/ausente é o padrão seguro: um recurso atrás
// de flag não vaza por acidente. Escopo global no MVP (não por organização);
// `enabledOrganizationIds` permite habilitação gradual (canário) sem schema novo.
model FeatureFlag {
  key                    String   @id
  description            String
  enabled                Boolean  @default(false)
  enabledOrganizationIds String[] @default([])
  updatedById            String?
  createdAt              DateTime @default(now()) @db.Timestamptz
  updatedAt              DateTime @updatedAt @db.Timestamptz

  updatedBy User? @relation("FeatureFlagUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
}

// Uma conexão nunca é apagada — vira REVOKED. Apagar a linha apagaria a
// origem das atividades já importadas (que continuam sendo histórico de
// treino do atleta) e a trilha de que o acesso um dia existiu.
enum ExternalConnectionStatus {
  ACTIVE
  REVOKED
}

// Resultado do vínculo atividade realizada → treino planejado.
// AMBIGUOUS é deliberadamente distinto de UNMATCHED: "havia dois candidatos e
// eu não escolhi" é uma informação diferente de "não havia nenhum", e é a
// única honesta quando o par não é determinável por data+modalidade.
enum ActivityMatchStatus {
  UNMATCHED
  MATCHED
  AMBIGUOUS
}

// ---------------------------------------------------------------------------
// 2. IDENTIDADE, TENANT E AUTENTICAÇÃO
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  name         String
  globalRole   Role     @default(ATHLETE)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz
  lockVersion  Int      @default(1)

  trainerProfile             TrainerProfile?
  athleteProfile             AthleteProfile?
  memberships                OrganizationMembership[]
  sessions                   Session[]
  requestedGenerationBatches GenerationBatch[]        @relation("GenerationRequestedBy")
  auditLogs                  AuditLog[]
  resolvedInsights           Insight[]                @relation("InsightResolvedBy")
  performedAssessments       Assessment[]             @relation("AssessmentPerformedBy")
  updatedFeatureFlags        FeatureFlag[]            @relation("FeatureFlagUpdatedBy")

  @@index([email])
}

// Infraestrutura de autenticação (ADR-002) — token opaco no cookie,
// apenas o hash HMAC-SHA256(AUTH_SECRET, token) é persistido aqui.
model Session {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  createdAt DateTime  @default(now()) @db.Timestamptz
  expiresAt DateTime  @db.Timestamptz
  revokedAt DateTime? @db.Timestamptz
  userAgent String?
  ipAddress String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  timezone    String   @default("America/Sao_Paulo")
  isActive    Boolean  @default(true)
  // Identidade comercial da assessoria (Etapa 4 §3). Todos opcionais — o
  // cadastro mínimo (name/slug) segue válido; o editor "Configurações da
  // assessoria" (fatia posterior) preenche o resto. `document` = CNPJ/CPF sem
  // máscara. NOTA: `TrainerProfile.companyName/crefCode` são a identidade
  // PROFISSIONAL do treinador — não confundir; a consolidação (quando a org
  // vira multi-treinador de fato) é trabalho futuro.
  // ponytail: `status` (lifecycle 4-estados) e defaults de faturamento
  // (defaultBillingDay/gracePeriod/…) ficam para as fatias que os consomem —
  // hoje `isActive` já é o gate de suspensão (guards) e não há cobrança da
  // assessoria ainda. Adicionar antes seria coluna morta.
  legalName   String?
  document    String?
  email       String?
  phone       String?
  website     String?
  logoUrl     String?
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz
  lockVersion Int      @default(1)

  memberships          OrganizationMembership[]
  subscriptions        Subscription[]
  invitations          AthleteInvitation[]
  relationships        CoachAthleteRelationship[]
  periodizations       Periodization[]
  workouts             Workout[]
  workoutTemplates     WorkoutTemplate[]
  calendarEvents       CalendarEvent[]
  generationBatches    GenerationBatch[]
  marketplacePlans     MarketplacePlan[]
  marketplacePurchases MarketplacePurchase[]
  reports              Report[]
  exercises            Exercise[]
  testResults          TestResult[]
  derivedMetrics       DerivedMetric[]
  assessments          Assessment[]
  auditLogs            AuditLog[]
  insights             Insight[]
  readinessCheckIns    ReadinessCheckIn[]
  externalConnections  ExternalConnection[]
  externalActivities   ExternalActivity[]
}

model OrganizationMembership {
  id             String           @id @default(uuid())
  userId         String
  organizationId String
  role           OrganizationRole @default(COACH)
  createdAt      DateTime         @default(now()) @db.Timestamptz
  updatedAt      DateTime         @updatedAt @db.Timestamptz

  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model TrainerProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  crefCode    String?
  companyName String?
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz
  lockVersion Int      @default(1)

  user              User                       @relation(fields: [userId], references: [id], onDelete: Restrict)
  relationships     CoachAthleteRelationship[]
  workouts          Workout[]
  workoutTemplates  WorkoutTemplate[]
  periodizations    Periodization[]
  calendarEvents    CalendarEvent[]
  generationBatches GenerationBatch[]
  marketplacePlans  MarketplacePlan[]
  invitations       AthleteInvitation[]
  testResults       TestResult[]
  reports           Report[]
  insights          Insight[]
}

model AthleteProfile {
  id          String    @id @default(uuid())
  userId      String?   @unique
  birthDate   DateTime? @db.Date
  gender      String?
  weightKg    Decimal?  @db.Decimal(5, 2)
  heightCm    Decimal?  @db.Decimal(5, 2)
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz
  lockVersion Int       @default(1)

  user                User?                      @relation(fields: [userId], references: [id], onDelete: Restrict)
  relationships       CoachAthleteRelationship[]
  periodizations      Periodization[]
  workouts            Workout[]
  calendarEvents      CalendarEvent[]
  generationBatches   GenerationBatch[]
  testResults         TestResult[]
  derivedMetrics      DerivedMetric[]
  assessments         Assessment[]
  reports             Report[]
  purchases           MarketplacePurchase[]
  invitations         AthleteInvitation[]
  insights            Insight[]
  readinessCheckIns   ReadinessCheckIn[]
  externalConnections ExternalConnection[]
  externalActivities  ExternalActivity[]
}

model CoachAthleteRelationship {
  id                String    @id @default(uuid())
  organizationId    String
  trainerId         String
  athleteId         String
  isActive          Boolean   @default(true)
  startedAt         DateTime  @default(now()) @db.Timestamptz
  endedAt           DateTime? @db.Timestamptz
  terminationReason String?
  createdAt         DateTime  @default(now()) @db.Timestamptz
  updatedAt         DateTime  @updatedAt @db.Timestamptz

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trainer      TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Restrict)
  athlete      AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Restrict)

  @@unique([organizationId, trainerId, athleteId])
  @@index([organizationId, athleteId])
}

model AthleteInvitation {
  id             String    @id @default(uuid())
  organizationId String
  trainerId      String
  athleteId      String
  email          String
  tokenHash      String    @unique
  expiresAt      DateTime  @db.Timestamptz
  isConsumed     Boolean   @default(false)
  consumedAt     DateTime? @db.Timestamptz
  isRevoked      Boolean   @default(false)
  revokedAt      DateTime? @db.Timestamptz
  resentCount    Int       @default(0)
  lastSentAt     DateTime? @db.Timestamptz
  createdAt      DateTime  @default(now()) @db.Timestamptz
  updatedAt      DateTime  @updatedAt @db.Timestamptz

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trainer      TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Restrict)
  athlete      AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
}

// ---------------------------------------------------------------------------
// 3. CORE ESTRATÉGICO: PERIODIZAÇÃO E MICROCICLOS
// ---------------------------------------------------------------------------

model Periodization {
  id                     String    @id @default(uuid())
  organizationId         String
  athleteId              String
  trainerId              String
  title                  String
  goal                   String
  startDate              DateTime  @db.Date
  endDate                DateTime  @db.Date
  // Fase 04 — camada estratégica rica. Campos nullable (aditivo; planos antigos
  // seguem válidos). `parameters` guarda os parâmetros por modalidade (VDOT/pace
  // na corrida, FTP/TSS no ciclismo, CSS na natação, séries/RIR/tonelagem na
  // musculação, padrão de movimento no funcional) — JSON validado por Zod na
  // escrita (`periodizationParametersSchema`), nunca lido cru.
  modality               Modality?
  targetEvent            String?
  level                  String?
  loadControlMethod      String?
  mainUnit               String?
  totalVolume            Decimal?  @db.Decimal(12, 2)
  mesocycleCount         Int?
  microcycleCount        Int?
  recoveryStrategy       String?
  difficultyDistribution String?
  autoGenerate           Boolean   @default(false)
  isDraft                Boolean   @default(false)
  notes                  String?
  parameters             Json?
  // Saída explicável do motor estratégico (Fase 1) congelada na geração:
  // regras aplicadas + versão + referências + confiança + dados ausentes.
  // Null em planos desenhados manualmente. Validado por Zod na escrita.
  strategyRationale      Json?
  createdAt              DateTime  @default(now()) @db.Timestamptz
  updatedAt              DateTime  @updatedAt @db.Timestamptz
  lockVersion            Int       @default(1)

  organization      Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete           AthleteProfile       @relation(fields: [athleteId], references: [id], onDelete: Restrict)
  trainer           TrainerProfile       @relation(fields: [trainerId], references: [id], onDelete: Restrict)
  phases            PeriodizationPhase[]
  weeks             TrainingWeek[]
  workouts          Workout[]
  generationBatches GenerationBatch[]

  @@index([organizationId, athleteId])
  @@index([trainerId])
}

model PeriodizationPhase {
  id              String   @id @default(uuid())
  periodizationId String
  name            String
  startDate       DateTime @db.Date
  endDate         DateTime @db.Date
  targetVolumeKm  Decimal? @db.Decimal(10, 2)
  targetIntensity String?
  sequence        Int
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz
  lockVersion     Int      @default(1)

  periodization Periodization  @relation(fields: [periodizationId], references: [id], onDelete: Cascade)
  weeks         TrainingWeek[]
  workouts      Workout[]

  @@unique([periodizationId, sequence])
  @@index([periodizationId, startDate])
}

model TrainingWeek {
  id              String   @id @default(uuid())
  periodizationId String
  phaseId         String?
  sequence        Int
  startDate       DateTime @db.Date
  endDate         DateTime @db.Date
  focus           String?
  targetVolume    Decimal? @db.Decimal(10, 2)
  targetIntensity String?
  isRecoveryWeek  Boolean  @default(false)
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz
  lockVersion     Int      @default(1)

  periodization Periodization       @relation(fields: [periodizationId], references: [id], onDelete: Cascade)
  phase         PeriodizationPhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  workouts      Workout[]

  @@unique([periodizationId, sequence])
  @@index([periodizationId, startDate])
}

// ---------------------------------------------------------------------------
// 4. PIPELINE DE AUTOMAÇÃO EM LOTE
// ---------------------------------------------------------------------------

model GenerationBatch {
  id                         String                @id @default(uuid())
  organizationId             String
  periodizationId            String
  athleteId                  String
  trainerId                  String
  requestedByUserId          String
  generationMode             GenerationMode
  generationVersion          Int
  algorithmVersion           String
  generationRationaleVersion String?
  contextSnapshot            Json
  scope                      GenerationScope
  status                     GenerationBatchStatus @default(PENDING)
  startedAt                  DateTime?             @db.Timestamptz
  completedAt                DateTime?             @db.Timestamptz
  failedAt                   DateTime?             @db.Timestamptz
  failureCode                String?
  createdAt                  DateTime              @default(now()) @db.Timestamptz
  updatedAt                  DateTime              @updatedAt @db.Timestamptz

  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  periodization   Periodization  @relation(fields: [periodizationId], references: [id], onDelete: Cascade)
  athlete         AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Restrict)
  trainer         TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Restrict)
  requestedByUser User           @relation("GenerationRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  workouts        Workout[]

  @@index([organizationId])
  @@index([periodizationId])
  @@index([athleteId, createdAt])
  @@index([trainerId, createdAt])
  @@index([status])
}

// ---------------------------------------------------------------------------
// 5. CORE OPERACIONAL: CALENDÁRIO, PRESCRIÇÃO E SESSÕES MULTIESPORTE
// ---------------------------------------------------------------------------
// Diretriz temporal: `plannedDate` é a data civil no fuso do atleta;
// `plannedStartAt`/`plannedEndAt` são instantes UTC; `plannedDate` nunca é
// convertido usando o fuso físico do servidor.

model Workout {
  id                         String           @id @default(uuid())
  organizationId             String
  athleteId                  String
  trainerId                  String
  periodizationId            String?
  periodizationPhaseId       String?
  trainingWeekId             String?
  generationBatchId          String?
  marketplacePurchaseId      String?
  workoutTemplateId          String?
  title                      String
  description                String?
  modality                   Modality
  status                     WorkoutStatus    @default(DRAFT)
  source                     WorkoutSource    @default(MANUAL)
  plannedDate                DateTime         @db.Date
  plannedStartAt             DateTime?        @db.Timestamptz
  plannedEndAt               DateTime?        @db.Timestamptz
  timezone                   String           @default("America/Sao_Paulo")
  generationMode             GenerationMode?
  generationVersion          Int?
  algorithmVersion           String?
  generationRationaleVersion String?
  confidenceLevel            ConfidenceLevel? @default(NOT_ASSESSED)
  generationRationale        Json?
  trainerModified            Boolean          @default(false)
  trainerModifiedAt          DateTime?        @db.Timestamptz
  trainerModifiedBy          String?
  modifiedFields             String[]         @default([])
  createdAt                  DateTime         @default(now()) @db.Timestamptz
  updatedAt                  DateTime         @updatedAt @db.Timestamptz
  lockVersion                Int              @default(1)

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete             AthleteProfile       @relation(fields: [athleteId], references: [id], onDelete: Restrict)
  trainer             TrainerProfile       @relation(fields: [trainerId], references: [id], onDelete: Restrict)
  periodization       Periodization?       @relation(fields: [periodizationId], references: [id], onDelete: Restrict)
  phase               PeriodizationPhase?  @relation(fields: [periodizationPhaseId], references: [id], onDelete: Restrict)
  trainingWeek        TrainingWeek?        @relation(fields: [trainingWeekId], references: [id], onDelete: SetNull)
  generationBatch     GenerationBatch?     @relation(fields: [generationBatchId], references: [id], onDelete: SetNull)
  marketplacePurchase MarketplacePurchase? @relation(fields: [marketplacePurchaseId], references: [id], onDelete: SetNull)
  workoutTemplate     WorkoutTemplate?     @relation(fields: [workoutTemplateId], references: [id], onDelete: SetNull)
  blocks              WorkoutBlock[]
  feedback            WorkoutFeedback?
  insights            Insight[]
  // Realizado importado de um provedor externo (Fase 11). Opcional e 1:1 — um
  // treino planejado nunca recebe duas atividades.
  externalActivity    ExternalActivity?

  @@index([organizationId, athleteId, plannedDate])
  // Consulta ampla da carteira: calendário "todos os atletas" e o motor de
  // atenção filtram por organização+treinador+data. Sem este composto, o
  // índice só de trainerId varre todas as datas do treinador (pesa com 200
  // atletas × meses de treino).
  @@index([organizationId, trainerId, plannedDate])
  @@index([trainerId])
  @@index([generationBatchId])
}

// Entidade oficial do MVP (aprovada após Fase 02A) — permite que
// `WorkoutSource.TEMPLATE`, já aprovado no enum, seja rastreável.
// Usa snapshot estruturado (`contentSnapshot`), não duplica a árvore
// completa de `Workout`/`WorkoutBlock`/`WorkoutExercise`. `contentSnapshot`
// é copiado no momento da clonagem — cópia imutável, nunca referência
// viva; ver comentário de topo deste arquivo para as regras completas.
model WorkoutTemplate {
  id              String   @id @default(uuid())
  organizationId  String
  trainerId       String
  title           String
  description     String?
  modality        Modality
  contentSnapshot Json
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz
  lockVersion     Int      @default(1)

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trainer      TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Restrict)
  workouts     Workout[]

  @@index([organizationId, trainerId])
}

model WorkoutBlock {
  id          String   @id @default(uuid())
  workoutId   String
  sequence    Int      @default(1)
  name        String?
  repetitions Int      @default(1)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  workout   Workout           @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]
  steps     WorkoutStep[]

  @@unique([workoutId, sequence])
}

model WorkoutExercise {
  id              String   @id @default(uuid())
  workoutBlockId  String
  exerciseId      String
  sequence        Int      @default(1)
  sets            Int
  reps            Int?
  durationSeconds Int?
  loadKg          Decimal? @db.Decimal(6, 2)
  rir             Int?
  rpeTarget       Float?
  restSeconds     Int?
  notes           String?
  // Proveniência da carga por %1RM (fatia D2) — paridade com WorkoutStep.metadata.
  metadata        Json?
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  block    WorkoutBlock @relation(fields: [workoutBlockId], references: [id], onDelete: Cascade)
  exercise Exercise     @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@unique([workoutBlockId, sequence])
}

model WorkoutStep {
  id              String               @id @default(uuid())
  workoutBlockId  String
  sequence        Int
  stepType        WorkoutStepType
  repetitions     Int?
  durationSeconds Int?
  distanceMeters  Int?
  targetType      IntensityTargetType?
  targetMin       Decimal?             @db.Decimal(10, 2)
  targetMax       Decimal?             @db.Decimal(10, 2)
  recoverySeconds Int?
  recoveryMeters  Int?
  metadata        Json?
  createdAt       DateTime             @default(now()) @db.Timestamptz
  updatedAt       DateTime             @updatedAt @db.Timestamptz

  block WorkoutBlock @relation(fields: [workoutBlockId], references: [id], onDelete: Cascade)

  @@unique([workoutBlockId, sequence])
}

model Exercise {
  id             String    @id @default(uuid())
  organizationId String?
  name           String
  category       String
  targetMuscles  String[]
  modality       Modality?
  equipment      String?
  level          String?
  description    String?
  videoUrl       String?
  // Rastreabilidade de vídeo (Fase 5): de onde o vídeo veio e sob qual
  // licença/observação — para não republicar mídia de terceiros sem crédito.
  videoSource    String?
  videoLicense   String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now()) @db.Timestamptz
  updatedAt      DateTime  @updatedAt @db.Timestamptz
  archivedAt     DateTime? @db.Timestamptz

  organization     Organization?     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workoutExercises WorkoutExercise[]

  @@unique([name, organizationId])
}

model CalendarEvent {
  id             String            @id @default(uuid())
  organizationId String
  athleteId      String
  trainerId      String?
  eventType      CalendarEventType
  title          String
  description    String?
  startAt        DateTime          @db.Timestamptz
  endAt          DateTime          @db.Timestamptz
  timezone       String            @default("America/Sao_Paulo")
  createdAt      DateTime          @default(now()) @db.Timestamptz
  updatedAt      DateTime          @updatedAt @db.Timestamptz
  lockVersion    Int               @default(1)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete      AthleteProfile  @relation(fields: [athleteId], references: [id], onDelete: Restrict)
  trainer      TrainerProfile? @relation(fields: [trainerId], references: [id], onDelete: SetNull)

  @@index([organizationId, athleteId, startAt])
}

// ---------------------------------------------------------------------------
// 6. SINTOMAS E EQUAÇÃO DE CARGA SUBJETIVA REALIZADA
// ---------------------------------------------------------------------------
// O frontend nunca calcula nem envia sessionRpeLoad — o backend calcula na
// mesma transação e ignora qualquer valor enviado pelo cliente.
// Fórmula: sessionRpeLoad = actualDurationMinutes × sessionRpe

model WorkoutFeedback {
  id                    String                   @id @default(uuid())
  workoutId             String                   @unique
  actualDurationMinutes Int?
  actualDistanceKm      Decimal?                 @db.Decimal(10, 3)
  sessionRpe            Float?
  sessionRpeLoad        Decimal?                 @db.Decimal(10, 2)
  loadStatus            SessionRpeLoadStatus     @default(NOT_AVAILABLE)
  completionSource      WorkoutCompletionSource?
  fatigueLevel          Int?
  recoveryLevel         Int?
  painLevel             Int?                     @default(0)
  painLaterality        String?
  painRegion            String?
  notes                 String?
  createdAt             DateTime                 @default(now()) @db.Timestamptz
  updatedAt             DateTime                 @updatedAt @db.Timestamptz

  workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// 7. INTELIGÊNCIA ESPORTIVA, TESTES E RELATÓRIOS
// ---------------------------------------------------------------------------

model TestResult {
  id                String   @id @default(uuid())
  organizationId    String
  athleteId         String
  trainerId         String
  testType          String
  resultValue       Decimal  @db.Decimal(12, 4)
  unit              String
  protocol          String?
  calculatedMetrics Json?
  performedAt       DateTime @db.Timestamptz
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz
  lockVersion       Int      @default(1)

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete      AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Restrict)
  trainer      TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Restrict)

  @@index([organizationId, athleteId, performedAt])
}

// Avaliação fisiológica/esportiva do atleta, VERSIONADA. Uma nova avaliação do
// mesmo tipo não apaga a anterior: a antiga vira SUPERSEDED (histórico
// preservado). As MEDIÇÕES do protocolo (FC repouso/máx; VDOT; FTP; CSS; 1RM…)
// vivem em `measurements` (JSON validado por Zod por protocolo — mesmo padrão de
// Periodization.parameters, nunca lido cru); as saídas derivadas por fórmula
// formal ficam em `derivedMetrics`. `TestResult` (genérico, sem uso) NÃO é
// substituído aqui — ver docs/ENKY_ASSESSMENTS_AND_ZONES_CURRENT_STATE.md.
model Assessment {
  id                String           @id @default(uuid())
  organizationId    String
  athleteId         String
  assessmentType    String // HEART_RATE | RUNNING | CYCLING | SWIMMING | STRENGTH | BODY_COMPOSITION
  modality          Modality? // nem todo tipo tem modalidade única (FC, composição)
  protocolCode      String
  protocolVersion   String           @default("1.0.0")
  assessmentDate    DateTime         @db.Date
  performedByUserId String?
  source            AssessmentSource @default(MANUAL)
  status            AssessmentStatus @default(DRAFT)
  confidence        ConfidenceLevel  @default(NOT_ASSESSED)
  validUntil        DateTime?        @db.Date
  measurements      Json // entradas do protocolo (Zod)
  derivedMetrics    Json? // saídas derivadas quando há fórmula formal
  notes             String?
  createdAt         DateTime         @default(now()) @db.Timestamptz
  updatedAt         DateTime         @updatedAt @db.Timestamptz
  lockVersion       Int              @default(1)

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete      AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Restrict)
  performedBy  User?          @relation("AssessmentPerformedBy", fields: [performedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, athleteId, assessmentType, assessmentDate], map: "idx_assessment_athlete_type_date")
  @@index([organizationId, athleteId, status], map: "idx_assessment_athlete_status")
}

model DerivedMetric {
  id             String              @id @default(uuid())
  organizationId String
  athleteId      String
  metricKey      String
  metricValue    Decimal             @db.Decimal(12, 4)
  periodStart    DateTime            @db.Date
  periodEnd      DateTime            @db.Date
  formulaVersion String              @default("1.0.0")
  status         DerivedMetricStatus @default(PENDING)
  createdAt      DateTime            @default(now()) @db.Timestamptz
  updatedAt      DateTime            @updatedAt @db.Timestamptz

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete      AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([organizationId, athleteId, metricKey, periodStart, periodEnd], map: "uq_derived_metric_period")
}

model Report {
  id              String       @id @default(uuid())
  organizationId  String
  athleteId       String
  trainerId       String
  status          ReportStatus @default(DRAFT)
  periodStart     DateTime     @db.Date
  periodEnd       DateTime     @db.Date
  metricsSnapshot Json
  insights        String?
  recommendations String?
  limitations     String?
  content         String?
  sharedAt        DateTime?    @db.Timestamptz
  createdAt       DateTime     @default(now()) @db.Timestamptz
  updatedAt       DateTime     @updatedAt @db.Timestamptz
  lockVersion     Int          @default(1)

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete      AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Restrict)
  trainer      TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Restrict)

  @@index([organizationId, athleteId])
}

// ENKY Intelligence — Insight persistido (02H). O motor de atenção calcula o
// Insight on-the-fly (modules/intelligence); esta tabela grava o ciclo
// detecção→exposição→ação→resultado para calibração. Uma linha por situação
// estável (fingerprint = athleteId:engine:regras), escopada por org+treinador
// como o resto do sistema. `content` guarda o Insight de 6 partes exposto.
model Insight {
  id             String        @id @default(uuid())
  organizationId String
  athleteId      String
  workoutId      String?
  trainerId      String
  engine         String
  risk           String
  rulesetVersion String        @default("1.0.0")
  fingerprint    String
  content        Json
  status         InsightStatus @default(NEW)
  note           String?
  outcome        String?
  resolvedById   String?
  resolvedAt     DateTime?     @db.Timestamptz
  createdAt      DateTime      @default(now()) @db.Timestamptz
  updatedAt      DateTime      @updatedAt @db.Timestamptz
  lockVersion    Int           @default(1)

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete      AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  workout      Workout?       @relation(fields: [workoutId], references: [id], onDelete: SetNull)
  trainer      TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  resolvedBy   User?          @relation("InsightResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@unique([organizationId, trainerId, fingerprint], map: "uq_insight_scope_fingerprint")
  @@index([organizationId, trainerId, status])
}

// Questionário de prontidão/recuperação (Fase II — item 5). Auto-relato diário
// e AVULSO do atleta (não atado a um treino, diferente de WorkoutFeedback):
// sono, fadiga, dor muscular, estresse, motivação. Coleta os sinais que faltam
// para o índice de prontidão (ENKY_METRIC_REGISTRY `readiness`). Campos são
// opcionais — preenchimento parcial reduz a confiança (classe "insuficiente").
// Um check-in por atleta por dia (upsert). Fase 03 acrescenta humor (`mood`),
// disposição (`disposition`) e dor localizada (`localizedPain`, texto livre —
// dado de saúde, redigido em log). `localizedPain` é qualitativo (onde dói) e
// não entra no escore numérico de prontidão; é sinalizado ao treinador.
model ReadinessCheckIn {
  id             String   @id @default(uuid())
  organizationId String
  athleteId      String
  checkInDate    DateTime @db.Date
  sleepHours     Decimal? @db.Decimal(4, 2)
  sleepQuality   Int?
  fatigue        Int?
  soreness       Int?
  stress         Int?
  motivation     Int?
  mood           Int?
  disposition    Int?
  localizedPain  String?
  notes          String?
  createdAt      DateTime @default(now()) @db.Timestamptz
  updatedAt      DateTime @updatedAt @db.Timestamptz
  lockVersion    Int      @default(1)

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete      AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([athleteId, checkInDate], map: "uq_readiness_athlete_day")
  @@index([organizationId, athleteId, checkInDate])
}

// ---------------------------------------------------------------------------
// 8. INFRAESTRUTURA FINANCEIRA, ASSINATURAS E MARKETPLACE IMUTÁVEL
// ---------------------------------------------------------------------------
// O checkout usa exclusivamente MarketplacePlanVersion.priceSnapshot da
// versão publicada. MarketplacePlan.price é o valor em edição da próxima versão.

model MarketplacePlan {
  id                 String            @id @default(uuid())
  organizationId     String
  trainerId          String
  title              String
  description        String
  price              Decimal           @db.Decimal(12, 2)
  modality           Modality
  targetLevel        String
  durationWeeks      Int
  status             MarketplaceStatus @default(DRAFT)
  publishedVersionId String?           @unique
  lockVersion        Int               @default(1)
  commercialVersion  Int               @default(1)
  createdAt          DateTime          @default(now()) @db.Timestamptz
  updatedAt          DateTime          @updatedAt @db.Timestamptz

  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trainer          TrainerProfile           @relation(fields: [trainerId], references: [id], onDelete: Restrict)
  versions         MarketplacePlanVersion[] @relation("PlanVersions")
  publishedVersion MarketplacePlanVersion?  @relation("PublishedPlanVersion", fields: [publishedVersionId], references: [id], onDelete: SetNull)
}

model MarketplacePlanVersion {
  id                  String   @id @default(uuid())
  marketplacePlanId   String
  titleSnapshot       String
  descriptionSnapshot String
  priceSnapshot       Decimal  @db.Decimal(12, 2)
  commercialVersion   Int
  contentSnapshot     Json
  createdAt           DateTime @default(now()) @db.Timestamptz

  plan             MarketplacePlan       @relation("PlanVersions", fields: [marketplacePlanId], references: [id], onDelete: Cascade)
  publishedByPlans MarketplacePlan?      @relation("PublishedPlanVersion")
  purchases        MarketplacePurchase[]

  @@unique([marketplacePlanId, commercialVersion])
}

model MarketplacePurchase {
  id                       String                    @id @default(uuid())
  organizationId           String
  marketplacePlanVersionId String
  athleteId                String
  status                   MarketplacePurchaseStatus @default(PENDING)
  pricePaid                Decimal                   @db.Decimal(12, 2)
  currency                 String                    @default("BRL") @db.VarChar(3)
  titleSnapshot            String
  activationStartDate      DateTime?                 @db.Date
  activatedAt              DateTime?                 @db.Timestamptz
  activationBatchId        String?
  purchasedAt              DateTime                  @default(now()) @db.Timestamptz
  lockVersion              Int                       @default(1)

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  version      MarketplacePlanVersion @relation(fields: [marketplacePlanVersionId], references: [id], onDelete: Restrict)
  athlete      AthleteProfile         @relation(fields: [athleteId], references: [id], onDelete: Restrict)
  transactions PaymentTransaction[]
  workouts     Workout[]
}

// Catálogo de planos da plataforma (Fase 10). É a ÚNICA fonte de verdade de
// preço no checkout — o cliente envia apenas `slug`, nunca valor (Interface
// Architecture v1.4 §1.D). `featuresLimits` é validado por
// `modules/subscriptions/plan-limits.ts` na leitura; ver `planLimitsSchema`.
model SubscriptionPlan {
  id             String       @id @default(uuid())
  slug           String       @unique
  name           String       @unique
  description    String?
  price          Decimal      @db.Decimal(12, 2)
  currency       String       @default("BRL") @db.VarChar(3)
  billingCycle   BillingCycle
  featuresLimits Json
  // Trial configurável por plano (Fase 05). 0 = sem trial. É o gateway que, no
  // checkout, aplica o período; a assinatura entra TRIALING até o primeiro
  // pagamento confirmado (webhook). Grátis e Assessoria = 0.
  trialDays      Int          @default(0)
  // Identificador do preço no gateway (ex.: Stripe `price_...`). Nulo no
  // plano grátis, que nunca vai a checkout.
  gatewayPriceId String?
  sortOrder      Int          @default(0)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now()) @db.Timestamptz
  updatedAt      DateTime     @updatedAt @db.Timestamptz

  subscriptions Subscription[]
}

// Assinatura da plataforma por organização. O índice parcial
// `uq_active_subscription_per_organization` (migração
// 20260710104346_add_native_postgres_constraints) garante no máximo uma
// assinatura não-terminal por organização — linhas CANCELLED/EXPIRED ficam
// como histórico.
//
// REGRA CRÍTICA (Fase 10): `status` só muda por evento de webhook confirmado
// e verificado — nunca por retorno do browser, nunca otimisticamente no
// checkout. Ver modules/payments/webhook-service.ts.
model Subscription {
  id                    String             @id @default(uuid())
  organizationId        String
  subscriptionPlanId    String
  status                SubscriptionStatus @default(INCOMPLETE)
  provider              String?
  gatewayCustomerId     String?
  gatewaySubscriptionId String?            @unique
  currentPeriodStart    DateTime?          @db.Timestamptz
  currentPeriodEnd      DateTime?          @db.Timestamptz
  cancelAtPeriodEnd     Boolean            @default(false)
  cancelledAt           DateTime?          @db.Timestamptz
  createdAt             DateTime           @default(now()) @db.Timestamptz
  updatedAt             DateTime           @updatedAt @db.Timestamptz
  lockVersion           Int                @default(1)

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  plan         SubscriptionPlan     @relation(fields: [subscriptionPlanId], references: [id], onDelete: Restrict)
  transactions PaymentTransaction[]
}

model PaymentTransaction {
  id                 String        @id @default(uuid())
  purchaseId         String?
  subscriptionId     String?
  gatewayRefId       String?       @unique
  amount             Decimal       @db.Decimal(12, 2)
  currency           String        @default("BRL") @db.VarChar(3)
  status             PaymentStatus @default(PENDING)
  idempotencyKey     String        @unique
  lockVersion        Int           @default(1)
  webhookEventId     String?       @unique
  webhookEventType   String?
  webhookPayloadHash String?
  webhookReceivedAt  DateTime?     @db.Timestamptz
  webhookProcessedAt DateTime?     @db.Timestamptz
  createdAt          DateTime      @default(now()) @db.Timestamptz
  updatedAt          DateTime      @updatedAt @db.Timestamptz

  purchase     MarketplacePurchase? @relation(fields: [purchaseId], references: [id], onDelete: Restrict)
  subscription Subscription?        @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)
}

// Livro-razão de eventos de webhook — a fronteira de idempotência da Fase 10.
//
// Por que uma tabela dedicada e não só `PaymentTransaction.webhookEventId`:
// aquele campo só cobre eventos que produzem uma transação. Eventos de ciclo
// de vida (assinatura atualizada, cancelada) não criam transação e ficariam
// sem proteção — um reenvio do gateway os reaplicaria. Aqui TODO evento é
// registrado antes de ser aplicado, e o `@@unique([provider, eventId])` é a
// trava: a segunda entrega do mesmo evento colide no INSERT dentro da mesma
// transação e o efeito é descartado inteiro (nunca parcialmente).
//
// `payloadHash` não participa da unicidade de propósito: se o gateway
// reenviar o MESMO eventId com corpo diferente, queremos ignorar (já
// processado) e registrar a divergência — não processar de novo.
model WebhookEvent {
  id          String             @id @default(uuid())
  provider    String
  eventId     String
  eventType   String
  payloadHash String
  status      WebhookEventStatus @default(PROCESSED)
  error       String?
  receivedAt  DateTime           @default(now()) @db.Timestamptz
  processedAt DateTime?          @db.Timestamptz

  @@unique([provider, eventId], map: "uq_webhook_provider_event")
  @@index([eventType])
  @@index([receivedAt])
}

// ---------------------------------------------------------------------------
// 9. INTEGRAÇÕES EXTERNAS (Fase 11 — Strava v1)
// ---------------------------------------------------------------------------
// Importa o REALIZADO de fontes externas para confrontar com o PLANEJADO que a
// ENKY prescreve. Regra estrutural da fase: a integração é um periférico — se
// ela cair inteira, o fluxo manual (prescrever, publicar, dar feedback)
// continua idêntico. Nenhum módulo de treino importa este.

// Conexão OAuth do atleta com um provedor. Um atleta tem no máximo UMA conexão
// por provedor (`uq_external_connection_athlete_provider`) — reconectar faz
// upsert desta mesma linha, e não acumula histórico de tokens mortos.
//
// SEGURANÇA DOS TOKENS: `accessToken`/`refreshToken` são gravados cifrados
// (AES-256-GCM, server/security/crypto.ts) e são NULOS quando a conexão está
// REVOKED. Nunca são selecionados para fora do módulo `integrations`, nunca
// entram em resposta de API e nunca em log — ver modules/integrations/README.md.
model ExternalConnection {
  id                String                   @id @default(uuid())
  organizationId    String
  athleteId         String
  provider          ExternalProvider
  // Id do atleta no provedor (Strava: `athlete.id`). É por ele que um evento
  // de webhook (`owner_id`) é resolvido para uma conexão local.
  providerAthleteId String
  status            ExternalConnectionStatus @default(ACTIVE)
  scope             String?
  accessToken       String?
  refreshToken      String?
  tokenExpiresAt    DateTime?                @db.Timestamptz
  connectedAt       DateTime                 @default(now()) @db.Timestamptz
  lastSyncedAt      DateTime?                @db.Timestamptz
  revokedAt         DateTime?                @db.Timestamptz
  createdAt         DateTime                 @default(now()) @db.Timestamptz
  updatedAt         DateTime                 @updatedAt @db.Timestamptz
  lockVersion       Int                      @default(1)

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete      AthleteProfile     @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  activities   ExternalActivity[]

  @@unique([athleteId, provider], map: "uq_external_connection_athlete_provider")
  @@index([provider, providerAthleteId])
  @@index([organizationId])
}

// Atividade realizada, importada de um provedor e normalizada para o
// vocabulário da ENKY. Os campos normalizados (`distanceMeters`, `movingSeconds`,
// `paceSecondsPerKm`, ...) são a interface; `rawType` guarda o tipo cru do
// provedor para não perder o que a normalização descartou.
//
// DEDUPLICAÇÃO: `uq_external_activity_provider_activity` é a trava. Importar
// duas vezes a mesma atividade — pelo webhook e pela importação manual ao
// mesmo tempo, que é o caso REAL — colide no índice em vez de duplicar. Não é
// um "SELECT antes do INSERT", que teria janela de corrida entre as duas vias.
model ExternalActivity {
  id                  String              @id @default(uuid())
  organizationId      String
  athleteId           String
  connectionId        String
  provider            ExternalProvider
  providerActivityId  String
  name                String?
  // Tipo cru do provedor (Strava `sport_type`: "Run", "VirtualRide", ...).
  rawType             String
  // Nulo quando o tipo do provedor não mapeia para nenhuma Modality nossa —
  // a atividade é importada mesmo assim (é volume real do atleta), só não
  // participa do vínculo por modalidade.
  modality            Modality?
  startedAt           DateTime            @db.Timestamptz
  // Data CIVIL no fuso em que a atividade aconteceu — vem do provedor, nunca
  // derivada do fuso do servidor. É o lado direito do vínculo com
  // `Workout.plannedDate`, que segue a mesma diretriz temporal (§5).
  localDate           DateTime            @db.Date
  timezone            String?
  distanceMeters      Int?
  movingSeconds       Int?
  elapsedSeconds      Int?
  // "Elevação, se disponível": nem todo dispositivo/atividade reporta.
  elevationGainMeters Int?
  // Ritmo médio canônico em s/km para TODA modalidade de distância, natação
  // inclusive (mesma decisão da Fase 6: o volume é sempre km). A convenção de
  // exibição — min/km, km/h, min/100m — é da UI, não do banco.
  paceSecondsPerKm    Int?
  workoutId           String?             @unique
  matchStatus         ActivityMatchStatus @default(UNMATCHED)
  matchedAt           DateTime?           @db.Timestamptz
  importedAt          DateTime            @default(now()) @db.Timestamptz
  updatedAt           DateTime            @updatedAt @db.Timestamptz

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete      AthleteProfile     @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  connection   ExternalConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  // SetNull, não Cascade: apagar/arquivar o treino planejado não pode apagar a
  // atividade que o atleta de fato executou — ela volta a ser realizado avulso.
  workout      Workout?           @relation(fields: [workoutId], references: [id], onDelete: SetNull)

  @@unique([provider, providerActivityId], map: "uq_external_activity_provider_activity")
  @@index([organizationId, athleteId, localDate])
  @@index([connectionId])
}

// ---------------------------------------------------------------------------
// 10. AUDITORIA MINIMIZADA
// ---------------------------------------------------------------------------

model AuditLog {
  id                 String         @id @default(uuid())
  userId             String?
  organizationId     String?
  action             String
  entityName         String
  entityId           String?
  actorType          AuditActorType @default(USER)
  ipAddress          String?
  requestId          String?
  correlationId      String?
  userAgent          String?
  reason             String?
  changedFields      String[]       @default([])
  previousValuesHash String?
  newValuesHash      String?
  createdAt          DateTime       @default(now()) @db.Timestamptz

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([correlationId])
  @@index([organizationId, createdAt])
}
