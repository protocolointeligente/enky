  createdAt      DateTime          @default(now()) @db.Timestamptz
  updatedAt      DateTime          @updatedAt @db.Timestamptz
  lockVersion    Int               @default(1)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete      AthleteProfile  @relation(fields: [athleteId], references: [id], onDelete: Restrict)
  trainer      TrainerProfile? @relation(fields: [trainerId], references: [id], onDelete: SetNull)

  @@index([organizationId, athleteId, startAt])
}

// ---------------------------------------------------------------------------
// 6. SINTOMAS E EQUAÇÃO DE CARGA SUBJETIVA REALIZADA
// ---------------------------------------------------------------------------
// O frontend nunca calcula nem envia sessionRpeLoad — o backend calcula na
// mesma transação e ignora qualquer valor enviado pelo cliente.
// Fórmula: sessionRpeLoad = actualDurationMinutes × sessionRpe

model WorkoutFeedback {
  id                    String                   @id @default(uuid())
  workoutId             String                   @unique
  actualDurationMinutes Int?
  actualDistanceKm      Decimal?                 @db.Decimal(10, 3)
  sessionRpe            Float?
  sessionRpeLoad        Decimal?                 @db.Decimal(10, 2)
  loadStatus            SessionRpeLoadStatus     @default(NOT_AVAILABLE)
  completionSource      WorkoutCompletionSource?
  fatigueLevel          Int?
  recoveryLevel         Int?
  painLevel             Int?                     @default(0)
  painLaterality        String?
  painRegion            String?
  notes                 String?
  createdAt             DateTime                 @default(now()) @db.Timestamptz
  updatedAt             DateTime                 @updatedAt @db.Timestamptz

  workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
}

// Uma execução = uma tentativa do atleta de realizar um treino. Persistida para
// permitir retomar, calcular aderência, entender abandono, sincronizar offline e
// auditar (§10). `workoutSnapshot` congela a prescrição no início (§19), então
// alterações posteriores do treinador não corrompem uma execução em andamento.
// Planejado-vs-realizado (§15): o planejado vive no snapshot; o realizado por
// etapa vive no `payload` dos eventos; totais realizados ficam no WorkoutFeedback.
model WorkoutExecution {
  id                String                 @id @default(uuid())
  organizationId    String
  athleteId         String
  workoutId         String
  status            WorkoutExecutionStatus @default(STARTED)
  startedAt         DateTime               @default(now()) @db.Timestamptz
  pausedAt          DateTime?              @db.Timestamptz
  resumedAt         DateTime?              @db.Timestamptz
  completedAt       DateTime?              @db.Timestamptz
  abandonedAt       DateTime?              @db.Timestamptz
  // Derivados por timestamp no domínio (não por setInterval) — ver modules/workout-execution.
  elapsedSeconds    Int                    @default(0)
  activeSeconds     Int                    @default(0)
  currentBlockIndex Int                    @default(0)
  currentStepIndex  Int                    @default(0)
  deviceId          String?
  clientVersion     String?
  offlineCreatedAt  DateTime?              @db.Timestamptz
  syncedAt          DateTime?              @db.Timestamptz
  // Idempotência de criação: o "start" vindo da fila offline não duplica execução.
  idempotencyKey    String                 @unique
  // Versão da prescrição no início (Workout.lockVersion) + cópia imutável (§18-19).
  workoutVersion    Int
  workoutSnapshot   Json
  createdAt         DateTime               @default(now()) @db.Timestamptz
  updatedAt         DateTime               @updatedAt @db.Timestamptz
  lockVersion       Int                    @default(1)

  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete      AthleteProfile          @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  workout      Workout                 @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  events       WorkoutExecutionEvent[]

  @@index([organizationId, athleteId])
  @@index([workoutId])
}

model WorkoutExecutionEvent {
  id             String                    @id @default(uuid())
  organizationId String
  executionId    String
  type           WorkoutExecutionEventType
  // Ordem determinística por execução (não confia só em createdAt do servidor).
  sequence       Int
  payload        Json?
  // Timestamp do CLIENTE (quando o evento realmente ocorreu, mesmo offline).
  occurredAt     DateTime                  @db.Timestamptz
  // Dedupe de eventos vindos da fila offline (§17).
  idempotencyKey String                    @unique
  createdAt      DateTime                  @default(now()) @db.Timestamptz

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  execution    WorkoutExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@unique([executionId, sequence])
  @@index([executionId])
}

// ---------------------------------------------------------------------------
// 7. INTELIGÊNCIA ESPORTIVA, TESTES E RELATÓRIOS
// ---------------------------------------------------------------------------

model TestResult {
  id                String   @id @default(uuid())
  organizationId    String
  athleteId         String
  trainerId         String
  testType          String
  resultValue       Decimal  @db.Decimal(12, 4)
  unit              String
  protocol          String?
  calculatedMetrics Json?
  performedAt       DateTime @db.Timestamptz
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz
  lockVersion       Int      @default(1)

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete      AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Restrict)
  trainer      TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Restrict)

  @@index([organizationId, athleteId, performedAt])
}

model DerivedMetric {
  id             String              @id @default(uuid())
  organizationId String
  athleteId      String
  metricKey      String
  metricValue    Decimal             @db.Decimal(12, 4)
  periodStart    DateTime            @db.Date
  periodEnd      DateTime            @db.Date
  formulaVersion String              @default("1.0.0")
  status         DerivedMetricStatus @default(PENDING)
  createdAt      DateTime            @default(now()) @db.Timestamptz
  updatedAt      DateTime            @updatedAt @db.Timestamptz

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete      AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([organizationId, athleteId, metricKey, periodStart, periodEnd], map: "uq_derived_metric_period")
}

model Report {
  id              String       @id @default(uuid())
  organizationId  String
  athleteId       String
  trainerId       String
  status          ReportStatus @default(DRAFT)
  periodStart     DateTime     @db.Date
  periodEnd       DateTime     @db.Date
  metricsSnapshot Json
  insights        String?
  recommendations String?
  limitations     String?
  content         String?
  sharedAt        DateTime?    @db.Timestamptz
  createdAt       DateTime     @default(now()) @db.Timestamptz
  updatedAt       DateTime     @updatedAt @db.Timestamptz
  lockVersion     Int          @default(1)

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete      AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Restrict)
  trainer      TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Restrict)

  @@index([organizationId, athleteId])
}

// ENKY Intelligence — Insight persistido (02H). O motor de atenção calcula o
// Insight on-the-fly (modules/intelligence); esta tabela grava o ciclo
// detecção→exposição→ação→resultado para calibração. Uma linha por situação
// estável (fingerprint = athleteId:engine:regras), escopada por org+treinador
// como o resto do sistema. `content` guarda o Insight de 6 partes exposto.
model Insight {
  id             String        @id @default(uuid())
  organizationId String
  athleteId      String
  workoutId      String?
  trainerId      String
  engine         String
  risk           String
  rulesetVersion String        @default("1.0.0")
  fingerprint    String
  content        Json
  status         InsightStatus @default(NEW)
  note           String?
  outcome        String?
  resolvedById   String?
  resolvedAt     DateTime?     @db.Timestamptz
  createdAt      DateTime      @default(now()) @db.Timestamptz
  updatedAt      DateTime      @updatedAt @db.Timestamptz
  lockVersion    Int           @default(1)

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete      AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  workout      Workout?       @relation(fields: [workoutId], references: [id], onDelete: SetNull)
  trainer      TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  resolvedBy   User?          @relation("InsightResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@unique([organizationId, trainerId, fingerprint], map: "uq_insight_scope_fingerprint")
  @@index([organizationId, trainerId, status])
}

// Questionário de prontidão/recuperação (Fase II — item 5). Auto-relato diário
// e AVULSO do atleta (não atado a um treino, diferente de WorkoutFeedback):
// sono, fadiga, dor muscular, estresse, motivação. Coleta os sinais que faltam
// para o índice de prontidão (ENKY_METRIC_REGISTRY `readiness`). Campos são
// opcionais — preenchimento parcial reduz a confiança (classe "insuficiente").
// Um check-in por atleta por dia (upsert). Fase 03 acrescenta humor (`mood`),
// disposição (`disposition`) e dor localizada (`localizedPain`, texto livre —
// dado de saúde, redigido em log). `localizedPain` é qualitativo (onde dói) e
// não entra no escore numérico de prontidão; é sinalizado ao treinador.
model ReadinessCheckIn {
  id             String   @id @default(uuid())
  organizationId String
  athleteId      String
  checkInDate    DateTime @db.Date
  sleepHours     Decimal? @db.Decimal(4, 2)
  sleepQuality   Int?
  fatigue        Int?
  soreness       Int?
  stress         Int?
  motivation     Int?
  mood           Int?
  disposition    Int?
  localizedPain  String?
  notes          String?
  createdAt      DateTime @default(now()) @db.Timestamptz
  updatedAt      DateTime @updatedAt @db.Timestamptz
  lockVersion    Int      @default(1)

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete      AthleteProfile @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([athleteId, checkInDate], map: "uq_readiness_athlete_day")
  @@index([organizationId, athleteId, checkInDate])
}

// ---------------------------------------------------------------------------
// 8. INFRAESTRUTURA FINANCEIRA, ASSINATURAS E MARKETPLACE IMUTÁVEL
// ---------------------------------------------------------------------------
// O checkout usa exclusivamente MarketplacePlanVersion.priceSnapshot da
// versão publicada. MarketplacePlan.price é o valor em edição da próxima versão.

model MarketplacePlan {
  id                 String            @id @default(uuid())
  organizationId     String
  trainerId          String
  title              String
  description        String
  price              Decimal           @db.Decimal(12, 2)
  modality           Modality
  targetLevel        String
  durationWeeks      Int
  status             MarketplaceStatus @default(DRAFT)
  publishedVersionId String?           @unique
  lockVersion        Int               @default(1)
  commercialVersion  Int               @default(1)
  createdAt          DateTime          @default(now()) @db.Timestamptz
  updatedAt          DateTime          @updatedAt @db.Timestamptz

  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trainer          TrainerProfile           @relation(fields: [trainerId], references: [id], onDelete: Restrict)
  versions         MarketplacePlanVersion[] @relation("PlanVersions")
  publishedVersion MarketplacePlanVersion?  @relation("PublishedPlanVersion", fields: [publishedVersionId], references: [id], onDelete: SetNull)
}

model MarketplacePlanVersion {
  id                  String   @id @default(uuid())
  marketplacePlanId   String
  titleSnapshot       String
  descriptionSnapshot String
  priceSnapshot       Decimal  @db.Decimal(12, 2)
  commercialVersion   Int
  contentSnapshot     Json
  createdAt           DateTime @default(now()) @db.Timestamptz

  plan             MarketplacePlan       @relation("PlanVersions", fields: [marketplacePlanId], references: [id], onDelete: Cascade)
  publishedByPlans MarketplacePlan?      @relation("PublishedPlanVersion")
  purchases        MarketplacePurchase[]

  @@unique([marketplacePlanId, commercialVersion])
}

model MarketplacePurchase {
  id                       String                    @id @default(uuid())
  organizationId           String
  marketplacePlanVersionId String
  athleteId                String
  status                   MarketplacePurchaseStatus @default(PENDING)
  pricePaid                Decimal                   @db.Decimal(12, 2)
  currency                 String                    @default("BRL") @db.VarChar(3)
  titleSnapshot            String
  activationStartDate      DateTime?                 @db.Date
  activatedAt              DateTime?                 @db.Timestamptz
  activationBatchId        String?
  purchasedAt              DateTime                  @default(now()) @db.Timestamptz
  lockVersion              Int                       @default(1)

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  version      MarketplacePlanVersion @relation(fields: [marketplacePlanVersionId], references: [id], onDelete: Restrict)
  athlete      AthleteProfile         @relation(fields: [athleteId], references: [id], onDelete: Restrict)
  transactions PaymentTransaction[]
  workouts     Workout[]
}

// Catálogo de planos da plataforma (Fase 10). É a ÚNICA fonte de verdade de
// preço no checkout — o cliente envia apenas `slug`, nunca valor (Interface
// Architecture v1.4 §1.D). `featuresLimits` é validado por
// `modules/subscriptions/plan-limits.ts` na leitura; ver `planLimitsSchema`.
model SubscriptionPlan {
  id             String       @id @default(uuid())
  slug           String       @unique
  name           String       @unique
  description    String?
  price          Decimal      @db.Decimal(12, 2)
  currency       String       @default("BRL") @db.VarChar(3)
  billingCycle   BillingCycle
  featuresLimits Json
  // Trial configurável por plano (Fase 05). 0 = sem trial. É o gateway que, no
  // checkout, aplica o período; a assinatura entra TRIALING até o primeiro
  // pagamento confirmado (webhook). Grátis e Assessoria = 0.
  trialDays      Int          @default(0)
  // Identificador do preço no gateway (ex.: Stripe `price_...`). Nulo no
  // plano grátis, que nunca vai a checkout.
  gatewayPriceId String?
  sortOrder      Int          @default(0)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now()) @db.Timestamptz
  updatedAt      DateTime     @updatedAt @db.Timestamptz

  subscriptions Subscription[]
}

// Assinatura da plataforma por organização. O índice parcial
// `uq_active_subscription_per_organization` (migração
// 20260710104346_add_native_postgres_constraints) garante no máximo uma
// assinatura não-terminal por organização — linhas CANCELLED/EXPIRED ficam
// como histórico.
//
// REGRA CRÍTICA (Fase 10): `status` só muda por evento de webhook confirmado
// e verificado — nunca por retorno do browser, nunca otimisticamente no
// checkout. Ver modules/payments/webhook-service.ts.
model Subscription {
  id                    String             @id @default(uuid())
  organizationId        String
  subscriptionPlanId    String
  status                SubscriptionStatus @default(INCOMPLETE)
  provider              String?
  gatewayCustomerId     String?
  gatewaySubscriptionId String?            @unique
  currentPeriodStart    DateTime?          @db.Timestamptz
  currentPeriodEnd      DateTime?          @db.Timestamptz
  cancelAtPeriodEnd     Boolean            @default(false)
  cancelledAt           DateTime?          @db.Timestamptz
  createdAt             DateTime           @default(now()) @db.Timestamptz
  updatedAt             DateTime           @updatedAt @db.Timestamptz
  lockVersion           Int                @default(1)

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  plan         SubscriptionPlan     @relation(fields: [subscriptionPlanId], references: [id], onDelete: Restrict)
  transactions PaymentTransaction[]
}

model PaymentTransaction {
  id                 String        @id @default(uuid())
  purchaseId         String?
  subscriptionId     String?
  gatewayRefId       String?       @unique
  amount             Decimal       @db.Decimal(12, 2)
  currency           String        @default("BRL") @db.VarChar(3)
  status             PaymentStatus @default(PENDING)
  idempotencyKey     String        @unique
  lockVersion        Int           @default(1)
  webhookEventId     String?       @unique
  webhookEventType   String?
  webhookPayloadHash String?
  webhookReceivedAt  DateTime?     @db.Timestamptz
  webhookProcessedAt DateTime?     @db.Timestamptz
  createdAt          DateTime      @default(now()) @db.Timestamptz
  updatedAt          DateTime      @updatedAt @db.Timestamptz

  marketplaceOrderId String?

  purchase         MarketplacePurchase? @relation(fields: [purchaseId], references: [id], onDelete: Restrict)
  subscription     Subscription?        @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)
  marketplaceOrder MarketplaceOrder?    @relation(fields: [marketplaceOrderId], references: [id], onDelete: Restrict)
}

// Livro-razão de eventos de webhook — a fronteira de idempotência da Fase 10.
//
// Por que uma tabela dedicada e não só `PaymentTransaction.webhookEventId`:
// aquele campo só cobre eventos que produzem uma transação. Eventos de ciclo
// de vida (assinatura atualizada, cancelada) não criam transação e ficariam
// sem proteção — um reenvio do gateway os reaplicaria. Aqui TODO evento é
// registrado antes de ser aplicado, e o `@@unique([provider, eventId])` é a
// trava: a segunda entrega do mesmo evento colide no INSERT dentro da mesma
// transação e o efeito é descartado inteiro (nunca parcialmente).
//
// `payloadHash` não participa da unicidade de propósito: se o gateway
// reenviar o MESMO eventId com corpo diferente, queremos ignorar (já
// processado) e registrar a divergência — não processar de novo.
model WebhookEvent {
  id          String             @id @default(uuid())
  provider    String
  eventId     String
  eventType   String
  payloadHash String
  status      WebhookEventStatus @default(PROCESSED)
  error       String?
  receivedAt  DateTime           @default(now()) @db.Timestamptz
  processedAt DateTime?          @db.Timestamptz

  @@unique([provider, eventId], map: "uq_webhook_provider_event")
  @@index([eventType])
  @@index([receivedAt])
}

// ---------------------------------------------------------------------------
// 9. INTEGRAÇÕES EXTERNAS (Fase 11 — Strava v1)
// ---------------------------------------------------------------------------
// Importa o REALIZADO de fontes externas para confrontar com o PLANEJADO que a
// ENKY prescreve. Regra estrutural da fase: a integração é um periférico — se
// ela cair inteira, o fluxo manual (prescrever, publicar, dar feedback)
// continua idêntico. Nenhum módulo de treino importa este.

// Conexão OAuth do atleta com um provedor. Um atleta tem no máximo UMA conexão
// por provedor (`uq_external_connection_athlete_provider`) — reconectar faz
// upsert desta mesma linha, e não acumula histórico de tokens mortos.
//
// SEGURANÇA DOS TOKENS: `accessToken`/`refreshToken` são gravados cifrados
// (AES-256-GCM, server/security/crypto.ts) e são NULOS quando a conexão está
// REVOKED. Nunca são selecionados para fora do módulo `integrations`, nunca
// entram em resposta de API e nunca em log — ver modules/integrations/README.md.
model ExternalConnection {
  id                String                   @id @default(uuid())
  organizationId    String
  athleteId         String
  provider          ExternalProvider
  // Id do atleta no provedor (Strava: `athlete.id`). É por ele que um evento
  // de webhook (`owner_id`) é resolvido para uma conexão local.
  providerAthleteId String
  status            ExternalConnectionStatus @default(ACTIVE)
  scope             String?
  accessToken       String?
  refreshToken      String?
  tokenExpiresAt    DateTime?                @db.Timestamptz
  connectedAt       DateTime                 @default(now()) @db.Timestamptz
  lastSyncedAt      DateTime?                @db.Timestamptz
  revokedAt         DateTime?                @db.Timestamptz
  createdAt         DateTime                 @default(now()) @db.Timestamptz
  updatedAt         DateTime                 @updatedAt @db.Timestamptz
  lockVersion       Int                      @default(1)

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete      AthleteProfile     @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  activities   ExternalActivity[]

  @@unique([athleteId, provider], map: "uq_external_connection_athlete_provider")
  @@index([provider, providerAthleteId])
  @@index([organizationId])
}

// Atividade realizada, importada de um provedor e normalizada para o
// vocabulário da ENKY. Os campos normalizados (`distanceMeters`, `movingSeconds`,
// `paceSecondsPerKm`, ...) são a interface; `rawType` guarda o tipo cru do
// provedor para não perder o que a normalização descartou.
//
// DEDUPLICAÇÃO: `uq_external_activity_provider_activity` é a trava. Importar
// duas vezes a mesma atividade — pelo webhook e pela importação manual ao
// mesmo tempo, que é o caso REAL — colide no índice em vez de duplicar. Não é
// um "SELECT antes do INSERT", que teria janela de corrida entre as duas vias.
model ExternalActivity {
  id                  String              @id @default(uuid())
  organizationId      String
  athleteId           String
  connectionId        String
  provider            ExternalProvider
  providerActivityId  String
  name                String?
  // Tipo cru do provedor (Strava `sport_type`: "Run", "VirtualRide", ...).
  rawType             String
  // Nulo quando o tipo do provedor não mapeia para nenhuma Modality nossa —
  // a atividade é importada mesmo assim (é volume real do atleta), só não
  // participa do vínculo por modalidade.
  modality            Modality?
  startedAt           DateTime            @db.Timestamptz
  // Data CIVIL no fuso em que a atividade aconteceu — vem do provedor, nunca
  // derivada do fuso do servidor. É o lado direito do vínculo com
  // `Workout.plannedDate`, que segue a mesma diretriz temporal (§5).
  localDate           DateTime            @db.Date
  timezone            String?
  distanceMeters      Int?
  movingSeconds       Int?
  elapsedSeconds      Int?
  // "Elevação, se disponível": nem todo dispositivo/atividade reporta.
  elevationGainMeters Int?
  // Ritmo médio canônico em s/km para TODA modalidade de distância, natação
  // inclusive (mesma decisão da Fase 6: o volume é sempre km). A convenção de
  // exibição — min/km, km/h, min/100m — é da UI, não do banco.
  paceSecondsPerKm    Int?
  workoutId           String?             @unique
  matchStatus         ActivityMatchStatus @default(UNMATCHED)
  matchedAt           DateTime?           @db.Timestamptz
  importedAt          DateTime            @default(now()) @db.Timestamptz
  updatedAt           DateTime            @updatedAt @db.Timestamptz

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete      AthleteProfile     @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  connection   ExternalConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  // SetNull, não Cascade: apagar/arquivar o treino planejado não pode apagar a
  // atividade que o atleta de fato executou — ela volta a ser realizado avulso.
  workout      Workout?           @relation(fields: [workoutId], references: [id], onDelete: SetNull)

  @@unique([provider, providerActivityId], map: "uq_external_activity_provider_activity")
  @@index([organizationId, athleteId, localDate])
  @@index([connectionId])
}

// ---------------------------------------------------------------------------
// 10. AUDITORIA MINIMIZADA
// ---------------------------------------------------------------------------

model AuditLog {
  id                 String         @id @default(uuid())
  userId             String?
  organizationId     String?
  action             String
  entityName         String
  entityId           String?
  actorType          AuditActorType @default(USER)
  ipAddress          String?
  requestId          String?
  correlationId      String?
  userAgent          String?
  reason             String?
  changedFields      String[]       @default([])
  previousValuesHash String?
  newValuesHash      String?
  createdAt          DateTime       @default(now()) @db.Timestamptz

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([correlationId])
  @@index([organizationId, createdAt])
}

// ---------------------------------------------------------------------------
// 10. MARKETPLACE PÚBLICO (Etapa 5) — família MarketplaceProduct
// ---------------------------------------------------------------------------
// Distinto de MarketplacePlan (venda estreita treinador→atleta, §8) e de
// Subscription (SaaS). Comprador = User qualquer. Snapshots (order item,
// entitlement, ledger) guardam ids como String, sem FK, por design de
// imutabilidade: a compra não muda se o produto/vendedor mudar depois.
// Detalhes: docs/ENKY_MARKETPLACE_PRODUCT_MODEL.md e docs/adr.

model MarketplaceSellerProfile {
  id                String                  @id @default(uuid())
  organizationId    String
  userId            String? // treinador responsável (id cru; sem FK)
  kind              MarketplaceSellerKind   @default(TRAINER)
  displayName       String
  slug              String                  @unique
  headline          String?
  bio               String?
  profileImageUrl   String?
  coverImageUrl     String?
  modalities        Modality[]              @default([])
  specialties       String[]                @default([])
  experienceYears   Int?
  certifications    String[]                @default([]) // declaradas; validação é processo à parte
  location          String?
  remoteService     Boolean                 @default(true)
  languages         String[]                @default([])
  website           String?
  socialLinks       Json?
  averageRating     Decimal                 @default(0) @db.Decimal(3, 2)
  reviewCount       Int                     @default(0)
  salesCount        Int                     @default(0)
  asaasWalletId     String? // carteira Asaas do vendedor — destino dos 90% no split
  status            MarketplaceSellerStatus @default(DRAFT)
  verificationNotes String?
  verifiedByUserId  String?
  verifiedAt        DateTime?               @db.Timestamptz
  rejectedAt        DateTime?               @db.Timestamptz
  rejectionReason   String?
  lockVersion       Int                     @default(1)
  createdAt         DateTime                @default(now()) @db.Timestamptz
  updatedAt         DateTime                @updatedAt @db.Timestamptz

  organization  Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products      MarketplaceProduct[]
  ledgerEntries MarketplaceLedgerEntry[]
  balance       MarketplaceSellerBalance?

  @@index([organizationId])
  @@index([userId])
  @@index([status])
}

model MarketplaceProduct {
  id                     String                   @id @default(uuid())
  sellerProfileId        String
  sellerOrganizationId   String // denormalizado p/ tenant isolation (id cru)
  sellerUserId           String?
  productType            MarketplaceProductType
  title                  String
  slug                   String                   @unique
  shortDescription       String?
  fullDescription        String?
  modality               Modality?
  level                  String?
  goal                   String?
  durationWeeks          Int?
  sessionsPerWeek        Int?
  deliveryType           MarketplaceDeliveryType  @default(DIGITAL_AUTOMATIC)
  price                  Decimal                  @db.Decimal(12, 2) // valor em edição da próxima versão; checkout usa priceSnapshot
  compareAtPrice         Decimal?                 @db.Decimal(12, 2)
  currency               String                   @default("BRL") @db.VarChar(3)
  status                 MarketplaceProductStatus @default(DRAFT)
  visibility             MarketplaceVisibility    @default(PUBLIC)
  isFeatured             Boolean                  @default(false)
  isEnkyOfficial         Boolean                  @default(false)
  officialCode           String?                  @unique // seed idempotente dos 20 planos oficiais
  requiresCoachApproval  Boolean                  @default(false)
  requiresAthleteProfile Boolean                  @default(false)
  refundPolicy           MarketplaceRefundPolicy  @default(NON_REFUNDABLE)
  refundWindowDays       Int?
  thumbnailUrl           String?
  coverImageUrl          String?
  previewVideoUrl        String?
  averageRating          Decimal                  @default(0) @db.Decimal(3, 2)
  reviewCount            Int                      @default(0)
  salesCount             Int                      @default(0)
  publishedVersionId     String?                  @unique
  commercialVersion      Int                      @default(1)
  lockVersion            Int                      @default(1)
  publishedAt            DateTime?                @db.Timestamptz
  createdAt              DateTime                 @default(now()) @db.Timestamptz
  updatedAt              DateTime                 @updatedAt @db.Timestamptz

  sellerProfile    MarketplaceSellerProfile     @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  versions         MarketplaceProductVersion[]  @relation("ProductVersions")
  publishedVersion MarketplaceProductVersion?   @relation("PublishedProductVersion", fields: [publishedVersionId], references: [id], onDelete: SetNull)
  variants         MarketplaceProductVariant[]
  categories       MarketplaceProductCategory[]
  orderItems       MarketplaceOrderItem[]
  reviews          MarketplaceReview[]
  entitlements     MarketplaceEntitlement[]
  cartItems        MarketplaceCartItem[]

  @@index([sellerOrganizationId])
  @@index([status, visibility])
  @@index([productType])
}

model MarketplaceProductVariant {
  id              String   @id @default(uuid())
  productId       String
  name            String
  description     String?
  price           Decimal  @db.Decimal(12, 2)
  compareAtPrice  Decimal? @db.Decimal(12, 2)
  currency        String   @default("BRL") @db.VarChar(3)
  durationWeeks   Int?
  sessionsPerWeek Int?
  supportLevel    String?
  maxAthletes     Int?
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  product    MarketplaceProduct     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems MarketplaceOrderItem[]
  cartItems  MarketplaceCartItem[]

  @@index([productId])
}

// Snapshot comercial imutável (mesmo padrão de MarketplacePlanVersion).
model MarketplaceProductVersion {
  id                String    @id @default(uuid())
  productId         String
  commercialVersion Int
  titleSnapshot     String
  priceSnapshot     Decimal   @db.Decimal(12, 2)
  currency          String    @default("BRL") @db.VarChar(3)
  contentSnapshot   Json // periodizationTemplateId, workoutTemplateIds, exerciseIds, contentAssetIds, coachServicePlanId, variantes
  changeLog         String?
  createdByUserId   String?
  publishedAt       DateTime? @db.Timestamptz
  createdAt         DateTime  @default(now()) @db.Timestamptz

  product            MarketplaceProduct       @relation("ProductVersions", fields: [productId], references: [id], onDelete: Cascade)
  publishedByProduct MarketplaceProduct?      @relation("PublishedProductVersion")
  orderItems         MarketplaceOrderItem[]
  entitlements       MarketplaceEntitlement[]

  @@unique([productId, commercialVersion])
}

model MarketplaceCategory {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  parentId  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz

  parent   MarketplaceCategory?         @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children MarketplaceCategory[]        @relation("CategoryTree")
  products MarketplaceProductCategory[]

  @@index([parentId])
}

model MarketplaceProductCategory {
  productId  String
  categoryId String

  product  MarketplaceProduct  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category MarketplaceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
}

model MarketplaceOrder {
  id                  String                    @id @default(uuid())
  buyerUserId         String
  buyerOrganizationId String?
  currency            String                    @default("BRL") @db.VarChar(3)
  subtotal            Decimal                   @db.Decimal(12, 2)
  discount            Decimal                   @default(0) @db.Decimal(12, 2)
  platformFee         Decimal                   @default(0) @db.Decimal(12, 2)
  gatewayFee          Decimal                   @default(0) @db.Decimal(12, 2)
  sellerAmount        Decimal                   @default(0) @db.Decimal(12, 2)
  total               Decimal                   @db.Decimal(12, 2)
  status              MarketplaceOrderStatus    @default(DRAFT)
  paymentStatus       PaymentStatus             @default(PENDING)
  deliveryStatus      MarketplaceDeliveryStatus @default(PENDING)
  gateway             String?
  gatewayReference    String?
  idempotencyKey      String                    @unique
  couponId            String?
  lockVersion         Int                       @default(1)
  createdAt           DateTime                  @default(now()) @db.Timestamptz
  updatedAt           DateTime                  @updatedAt @db.Timestamptz
  paidAt              DateTime?                 @db.Timestamptz
  cancelledAt         DateTime?                 @db.Timestamptz
  refundedAt          DateTime?                 @db.Timestamptz

  buyer         User                      @relation(fields: [buyerUserId], references: [id], onDelete: Restrict)
  buyerOrg      Organization?             @relation(fields: [buyerOrganizationId], references: [id], onDelete: SetNull)
  coupon        MarketplaceCoupon?        @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items         MarketplaceOrderItem[]
  transactions  PaymentTransaction[]
  entitlements  MarketplaceEntitlement[]
  paymentEvents MarketplacePaymentEvent[]
  ledgerEntries MarketplaceLedgerEntry[]
  reviews       MarketplaceReview[]

  @@index([buyerUserId])
  @@index([buyerOrganizationId])
  @@index([status])
}

// Snapshot imutável do item comprado (ids sem FK são snapshots).
model MarketplaceOrderItem {
  id                   String                 @id @default(uuid())
  orderId              String
  productId            String?
  productVersionId     String?
  variantId            String?
  sellerProfileId      String?
  sellerOrganizationId String
  sellerUserId         String?
  title                String
  productType          MarketplaceProductType
  quantity             Int                    @default(1)
  unitPrice            Decimal                @db.Decimal(12, 2)
  platformFee          Decimal                @default(0) @db.Decimal(12, 2)
  sellerAmount         Decimal                @default(0) @db.Decimal(12, 2)
  commissionSnapshot   Json? // regra de comissão aplicada no momento da venda
  deliveryPayload      Json?
  createdAt            DateTime               @default(now()) @db.Timestamptz

  order          MarketplaceOrder           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        MarketplaceProduct?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  productVersion MarketplaceProductVersion? @relation(fields: [productVersionId], references: [id], onDelete: SetNull)
  variant        MarketplaceProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  entitlements   MarketplaceEntitlement[]
  reviews        MarketplaceReview[]
  ledgerEntries  MarketplaceLedgerEntry[]

  @@index([orderId])
  @@index([sellerOrganizationId])
}

model MarketplaceCart {
  id        String    @id @default(uuid())
  userId    String
  currency  String    @default("BRL") @db.VarChar(3)
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  expiresAt DateTime? @db.Timestamptz

  user  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  items MarketplaceCartItem[]

  @@index([userId])
}

model MarketplaceCartItem {
  id        String   @id @default(uuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @db.Timestamptz

  cart    MarketplaceCart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product MarketplaceProduct         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant MarketplaceProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  // ponytail: unique ignora linhas com variantId NULL (semântica NULL do Postgres);
  // dedupe de item sem variante fica na camada de serviço, não vale índice parcial agora.
  @@unique([cartId, productId, variantId])
  @@index([cartId])
}

model MarketplaceEntitlement {
  id                  String                       @id @default(uuid())
  buyerUserId         String
  buyerOrganizationId String?
  orderId             String?
  orderItemId         String?                      @unique // idempotência de entrega: 1 entitlement por item
  productId           String?
  productVersionId    String?
  entitlementType     MarketplaceProductType
  status              MarketplaceEntitlementStatus @default(PENDING)
  deliveryPayload     Json?
  startsAt            DateTime?                    @db.Timestamptz
  expiresAt           DateTime?                    @db.Timestamptz
  revokedAt           DateTime?                    @db.Timestamptz
  createdAt           DateTime                     @default(now()) @db.Timestamptz
  updatedAt           DateTime                     @updatedAt @db.Timestamptz

  buyer          User                       @relation(fields: [buyerUserId], references: [id], onDelete: Restrict)
  order          MarketplaceOrder?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderItem      MarketplaceOrderItem?      @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  product        MarketplaceProduct?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  productVersion MarketplaceProductVersion? @relation(fields: [productVersionId], references: [id], onDelete: SetNull)

  @@index([buyerUserId])
}

model MarketplaceReview {
  id               String                  @id @default(uuid())
  orderItemId      String                  @unique // 1 avaliação por item comprado
  orderId          String?
  productId        String
  sellerProfileId  String?
  reviewerUserId   String
  rating           Int // validação 1..5 na camada de serviço (Zod)
  title            String?
  comment          String?
  status           MarketplaceReviewStatus @default(PENDING)
  verifiedPurchase Boolean                 @default(true)
  createdAt        DateTime                @default(now()) @db.Timestamptz
  updatedAt        DateTime                @updatedAt @db.Timestamptz

  orderItem MarketplaceOrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  order     MarketplaceOrder?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  product   MarketplaceProduct         @relation(fields: [productId], references: [id], onDelete: Cascade)
  reviewer  User                       @relation(fields: [reviewerUserId], references: [id], onDelete: Restrict)
  response  MarketplaceReviewResponse?

  @@index([productId, status])
}

model MarketplaceReviewResponse {
  id              String   @id @default(uuid())
  reviewId        String   @unique
  responderUserId String
  comment         String
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  review MarketplaceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model MarketplaceCommissionRule {
  id             String                  @id @default(uuid())
  sellerKind     MarketplaceSellerKind?
  productType    MarketplaceProductType?
  percentage     Decimal                 @default(0) @db.Decimal(5, 2)
  fixedFee       Decimal                 @default(0) @db.Decimal(12, 2)
  currency       String                  @default("BRL") @db.VarChar(3)
  effectiveFrom  DateTime                @db.Timestamptz
  effectiveUntil DateTime?               @db.Timestamptz
  isActive       Boolean                 @default(true)
  createdAt      DateTime                @default(now()) @db.Timestamptz

  @@index([sellerKind, productType, isActive])
}

// Fonte de verdade do saldo do vendedor (§28). O saldo em MarketplaceSellerBalance
// é cache derivável — nunca mutar sem lançar aqui.
model MarketplaceLedgerEntry {
  id                   String                       @id @default(uuid())
  sellerProfileId      String
  sellerOrganizationId String
  orderId              String?
  orderItemId          String?
  type                 MarketplaceLedgerEntryType
  amount               Decimal                      @db.Decimal(12, 2) // sinal: +crédito / -débito
  currency             String                       @default("BRL") @db.VarChar(3)
  status               MarketplaceLedgerEntryStatus @default(PENDING)
  availableAt          DateTime?                    @db.Timestamptz
  description          String?
  createdAt            DateTime                     @default(now()) @db.Timestamptz

  sellerProfile MarketplaceSellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  order         MarketplaceOrder?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderItem     MarketplaceOrderItem?    @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

  @@index([sellerProfileId, status])
  @@index([orderId])
}

model MarketplaceSellerBalance {
  id              String   @id @default(uuid())
  sellerProfileId String   @unique
  currency        String   @default("BRL") @db.VarChar(3)
  pendingAmount   Decimal  @default(0) @db.Decimal(12, 2) // cache derivável do ledger
  availableAmount Decimal  @default(0) @db.Decimal(12, 2)
  paidAmount      Decimal  @default(0) @db.Decimal(12, 2)
  lockVersion     Int      @default(1)
  updatedAt       DateTime @updatedAt @db.Timestamptz

  sellerProfile MarketplaceSellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
}

// Log cru de webhook do gateway (§21) — dedupe + reprocesso; separado de
// PaymentTransaction (que carrega o dinheiro e sua própria idempotência).
model MarketplacePaymentEvent {
  id              String    @id @default(uuid())
  gateway         String
  externalEventId String
  eventType       String
  payloadHash     String
  status          String    @default("RECEIVED") // RECEIVED / PROCESSED / FAILED / IGNORED
  orderId         String?
  processedAt     DateTime? @db.Timestamptz
  failureReason   String?
  createdAt       DateTime  @default(now()) @db.Timestamptz

  order MarketplaceOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([gateway, externalEventId]) // idempotência do webhook
  @@index([orderId])
}

model MarketplaceCoupon {
  id                   String                @id @default(uuid())
  code                 String                @unique
  discountType         MarketplaceCouponType
  discountValue        Decimal               @db.Decimal(12, 2)
  minimumAmount        Decimal?              @db.Decimal(12, 2)
  maximumDiscount      Decimal?              @db.Decimal(12, 2)
  currency             String                @default("BRL") @db.VarChar(3)
  startsAt             DateTime?             @db.Timestamptz
  endsAt               DateTime?             @db.Timestamptz
  usageLimit           Int?
  usageLimitPerUser    Int?
  usageCount           Int                   @default(0)
  sellerOrganizationId String?
  productId            String?
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now()) @db.Timestamptz

  organization Organization?                 @relation(fields: [sellerOrganizationId], references: [id], onDelete: Cascade)
  orders       MarketplaceOrder[]
  redemptions  MarketplaceCouponRedemption[]

  @@index([code])
}

model MarketplaceCouponRedemption {
  id        String   @id @default(uuid())
  couponId  String
  userId    String
  orderId   String?
  createdAt DateTime @default(now()) @db.Timestamptz

  coupon MarketplaceCoupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId, userId])
}
