// ENKY OS — Prisma schema
//
// Fase 02A: schema expandido do modelo mínimo da Fase 01 para o modelo
// completo necessário à fundação e ao fluxo central do MVP, seguindo o
// Data Model Specification v1.2.1 (documento de maior hierarquia para
// banco/enums/relações/índices/constraints) e as reconciliações da
// Fase 01.5 (achados F1–F9, ADR-001, ADR-002).
//
// Duas extensões sobre o Data Model v1.2.1 original, ambas aprovadas
// formalmente após o relatório de Fase 02A:
//   - `Session`: infraestrutura de autenticação (ADR-002-authentication.md),
//     não uma entidade de produto do Data Model.
//   - `WorkoutTemplate` + `Workout.workoutTemplateId`: entidade oficial do
//     MVP (aprovada — a Interface Architecture v1.4 já prevê biblioteca de
//     modelos e substituição por template). Regras de clonagem:
//       * um Workout clonado de um template mantém `source = TEMPLATE`
//         permanentemente — não muda para MANUAL após edição;
//       * `contentSnapshot` é copiado no momento da clonagem e nunca mais
//         sincronizado — editar o Workout clonado NUNCA altera o
//         WorkoutTemplate original, e editar o template NUNCA retroage
//         sobre clones já criados (cópia imutável, não referência viva).
//
// Fora do escopo desta fase (ver relatório de Fase 02A): `Notification`
// interna (adiada — decisão: `AthleteInvitation` controla o convite,
// e-mail transacional entrega o link, falhas de envio são logadas;
// notificação interna só entra quando existir central de notificações
// real no produto — não criar tabela "porque pode ser útil"),
// `AthleteGroup`, mensageria completa, anexos genéricos,
// `AIRecommendation` independente (todos classificados como pós-MVP ou
// substituídos em enky_os_specification.md §12).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// 1. ENUMS
// ---------------------------------------------------------------------------

