# ENKY OS — Environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ---------------------------------------------------------------------------
# Database (PostgreSQL, read by prisma/schema.prisma via env("DATABASE_URL"))
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/enky?schema=public"

# Used by Prisma's `directUrl` (prisma/schema.prisma datasource block) for
# migrations and introspection, which need a non-pooled connection — required
# by providers that split pooled vs. direct (Neon, Supabase, PgBouncer).
# Same database as DATABASE_URL, just the unpooled endpoint/port.
DIRECT_URL="postgresql://user:password@localhost:5432/enky?schema=public"

# ---------------------------------------------------------------------------
# Auth (server/auth) — see docs/ARCHITECTURE.md
# ---------------------------------------------------------------------------
# HMAC signing secret for session cookies AND athlete invitation tokens
# (server/auth/session.ts, modules/athletes/invitation-token.ts). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Minimum 32 characters. Never reuse across environments. Rotating it
# invalidates every session and every pending invitation at once.
AUTH_SECRET=""

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# Also the trusted origin for CSRF checks on every mutating route
# (server/security/csrf.ts) and the base of every invitation activation
# link — must match the real deployed URL exactly, protocol included.
APP_URL="http://localhost:3000"
NODE_ENV="development"
LOG_LEVEL="info"

# ---------------------------------------------------------------------------
# E-mail transacional (Resend) — usado a partir da Fase 02D pelo convite de
# atleta (infrastructure/mail). Em desenvolvimento, deixe ambos VAZIOS: o
# sistema cai para o DevInvitationMailer, que apenas loga o link de ativação
# no console. Em produção, AMBOS são obrigatórios — sem eles, enviar um
# convite retorna erro operacional explícito (nunca "sucede" no vazio).
#   - EMAIL_PROVIDER_API_KEY: a API key da Resend (começa com "re_").
#   - EMAIL_FROM: remetente verificado na Resend, ex.: "ENKY <no-reply@enky.com.br>".
EMAIL_PROVIDER_API_KEY=""
EMAIL_FROM=""

# ---------------------------------------------------------------------------
# Reserved for future providers (Fase 03+) — do not fill with real
# credentials until the corresponding module actually reads them.
# ---------------------------------------------------------------------------
PAYMENT_PROVIDER_SECRET_KEY=""
PAYMENT_PROVIDER_WEBHOOK_SECRET=""
STORAGE_PROVIDER_ACCESS_KEY=""
STORAGE_PROVIDER_SECRET_KEY=""
AI_PROVIDER_API_KEY=""
