# ENKY OS — Environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ---------------------------------------------------------------------------
# Database (PostgreSQL, read by prisma/schema.prisma via env("DATABASE_URL"))
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/enky?schema=public"

# Used by Prisma's `directUrl` (prisma/schema.prisma datasource block) for
# migrations and introspection, which need a non-pooled connection — required
# by providers that split pooled vs. direct (Neon, Supabase, PgBouncer).
# Same database as DATABASE_URL, just the unpooled endpoint/port.
DIRECT_URL="postgresql://user:password@localhost:5432/enky?schema=public"

# ---------------------------------------------------------------------------
# Auth (server/auth) — see docs/ARCHITECTURE.md
# ---------------------------------------------------------------------------
# HMAC signing secret for session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Minimum 32 characters. Never reuse across environments.
AUTH_SECRET=""

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_URL="http://localhost:3000"
NODE_ENV="development"
LOG_LEVEL="info"

# ---------------------------------------------------------------------------
# Reserved for future providers (Fase 03+) — do not fill with real
# credentials until the corresponding module actually reads them.
# ---------------------------------------------------------------------------
EMAIL_PROVIDER_API_KEY=""
PAYMENT_PROVIDER_SECRET_KEY=""
PAYMENT_PROVIDER_WEBHOOK_SECRET=""
STORAGE_PROVIDER_ACCESS_KEY=""
STORAGE_PROVIDER_SECRET_KEY=""
AI_PROVIDER_API_KEY=""
