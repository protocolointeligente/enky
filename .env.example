# ENKY OS — Environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ---------------------------------------------------------------------------
# Database (PostgreSQL, read by prisma/schema.prisma via env("DATABASE_URL"))
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/enky?schema=public"

# Used by Prisma's `directUrl` (prisma/schema.prisma datasource block) for
# migrations and introspection, which need a non-pooled connection — required
# by providers that split pooled vs. direct (Neon, Supabase, PgBouncer).
# Same database as DATABASE_URL, just the unpooled endpoint/port.
DIRECT_URL="postgresql://user:password@localhost:5432/enky?schema=public"

# ---------------------------------------------------------------------------
# Auth (server/auth) — see docs/ARCHITECTURE.md
# ---------------------------------------------------------------------------
# HMAC signing secret for session cookies AND athlete invitation tokens
# (server/auth/session.ts, modules/athletes/invitation-token.ts). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Minimum 32 characters. Never reuse across environments. Rotating it
# invalidates every session and every pending invitation at once.
AUTH_SECRET=""

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# Also the trusted origin for CSRF checks on every mutating route
# (server/security/csrf.ts) and the base of every invitation activation
# link — must match the real deployed URL exactly, protocol included.
APP_URL="http://localhost:3000"
NODE_ENV="development"
LOG_LEVEL="info"

# ---------------------------------------------------------------------------
# E-mail transacional (Resend) — usado a partir da Fase 02D pelo convite de
# atleta (infrastructure/mail). Em desenvolvimento, deixe ambos VAZIOS: o
# sistema cai para o DevInvitationMailer, que apenas loga o link de ativação
# no console. Em produção, AMBOS são obrigatórios — sem eles, enviar um
# convite retorna erro operacional explícito (nunca "sucede" no vazio).
#   - EMAIL_PROVIDER_API_KEY: a API key da Resend (começa com "re_").
#   - EMAIL_FROM: remetente verificado na Resend, ex.: "ENKY <no-reply@enky.com.br>".
EMAIL_PROVIDER_API_KEY=""
EMAIL_FROM=""

# ---------------------------------------------------------------------------
# Rate limiting distribuído (Upstash Redis REST) — server/security/rate-limit.ts
# ---------------------------------------------------------------------------
# Store compartilhado do rate limit. Em development/test, deixe VAZIOS: o
# sistema cai para o limitador em memória (por processo).
#
# Em PRODUÇÃO, configure AMBOS. Sem eles o app NÃO cai — degrada para memória e
# grita no log —, mas a contagem vira por instância: várias instâncias
# multiplicam o limite efetivo e um redeploy zera as janelas. Ou seja: funciona,
# mas a proteção contra brute-force fica bem pior que o desenhado.
#
# UPSTASH_REDIS_REST_URL precisa ser a REST URL (https://algo.upstash.io) da aba
# "REST API" do console — NÃO a connection string redis://, porque o adapter
# fala HTTP. Crie um banco grátis em https://console.upstash.com.
#
# Na Vercel: marque o escopo Production nas DUAS variáveis e faça REDEPLOY —
# variável nova só passa a valer em deployment novo.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ---------------------------------------------------------------------------
# Gateway de pagamento — Asaas (Fase 10) — modules/payments
# ---------------------------------------------------------------------------
# Em development/test, deixe AMBOS VAZIOS: o sistema cai para o
# FakePaymentProvider, que não fala com a rede e não cria cobrança real.
# Em PRODUÇÃO, AMBOS são obrigatórios — sem eles, checkout e webhook falham com
# erro explícito. NUNCA há fallback para o provedor falso fora de
# development/test: ele aceitaria "pagamento confirmado" forjado.
#
# Preview na Vercel roda com NODE_ENV=production. Para testar pagamento em
# Preview, use as chaves de SANDBOX ($aact_hmlg_...) — o adapter detecta o
# prefixo e fala com api-sandbox.asaas.com sozinho, sem variável extra.
#
# PAYMENT_PROVIDER_SECRET_KEY: API key da conta Asaas (Configurações →
#   Integrações). Vai no header `access_token`. Preserve o "$" inicial.
PAYMENT_PROVIDER_SECRET_KEY=""
# PAYMENT_PROVIDER_WEBHOOK_SECRET: segredo compartilhado do webhook. O Asaas
#   NÃO assina o corpo (ao contrário da Stripe) — ele devolve este valor no
#   header `asaas-access-token` de cada POST, e é a ÚNICA prova de que o evento
#   veio dele. Cadastre em Configurações → Integrações → Webhooks, no campo
#   "Token de autenticação", apontando para:
#       https://<seu-dominio>/api/webhooks/payment-provider
#   Regras: nunca use a API key aqui (o Asaas proíbe); gere um valor aleatório
#   longo; a URL precisa ser HTTPS — o segredo viaja em claro no header.
#   Gere com:
#     node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
PAYMENT_PROVIDER_WEBHOOK_SECRET=""

# ---------------------------------------------------------------------------
# Integração Strava (Fase 11) — modules/integrations
# ---------------------------------------------------------------------------
# TODAS opcionais, e aqui isso é mais forte que "o build precisa passar": a
# integração é um PERIFÉRICO. Sem elas, a instalação é válida e completa — as
# rotas de integração respondem 422 explicando, e prescrever/publicar/executar
# treino não muda em nada. Não há provedor falso: um fake ativo por engano
# escreveria atividade INVENTADA no histórico do atleta (ver
# modules/integrations/README.md).
#
# Cadastre a aplicação em https://www.strava.com/settings/api. O "Authorization
# Callback Domain" deve ser o domínio do deployment (só o domínio — sem
# protocolo e sem caminho); o callback usado é
#   https://<seu-dominio>/api/athlete/integrations/strava/callback
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""

# Segredo NOSSO, escolhido por nós, devolvido pelo Strava no handshake GET que
# cria a inscrição do webhook. É a única prova de que o endpoint é nosso — e
# NÃO autentica os POSTs de evento: o Strava não os assina (o desenho não
# depende disso; ver o README do módulo). Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
STRAVA_WEBHOOK_VERIFY_TOKEN=""

# Id da inscrição devolvido pelo Strava ao criá-la (ver README do módulo, §Setup).
# Opcional. O Strava aceita UMA inscrição por aplicação: se preview e produção
# compartilham o mesmo app, isto faz cada ambiente descartar o evento do outro.
STRAVA_WEBHOOK_SUBSCRIPTION_ID=""

# ---------------------------------------------------------------------------
# Reserved for future providers — do not fill with real credentials until the
# corresponding module actually reads them.
# ---------------------------------------------------------------------------
STORAGE_PROVIDER_ACCESS_KEY=""
STORAGE_PROVIDER_SECRET_KEY=""
AI_PROVIDER_API_KEY=""

# Importação de exercícios globais (scripts de import manual, nunca runtime).
# MuscleWiki: header X-API-Key; acesso direto da API exige tier pago (~US$10/mês).
MUSCLEWIKI_API_KEY=""
# ExerciseDB via RapidAPI: header X-RapidAPI-Key; tier free (rate-limited), GIFs.
EXERCISEDB_RAPIDAPI_KEY=""

# ---------------------------------------------------------------------------
# Web Push / VAPID (§14 — notificações push do PWA)
# ---------------------------------------------------------------------------
# Gere o par de chaves uma vez com:
#   npx web-push generate-vapid-keys
# A PÚBLICA vai para o cliente (precisa do prefixo NEXT_PUBLIC_ para chegar ao
# bundle); a PRIVADA é server-only. Sem elas, o push fica desligado e o app
# funciona normalmente (get-push-provider.ts recusa fora de dev).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# Contato do remetente exigido pelo protocolo Web Push: "mailto:voce@dominio"
# ou uma URL https. Aparece para os push services em caso de abuso.
VAPID_SUBJECT="mailto:suporte@enky.app"
